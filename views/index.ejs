<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>🛒 <%= title %></h1>
        <p>System do zbierania zamówień z transmisji na żywo.</p>

        <!-- Formularz wyszukiwarki dla klienta -->
        <h3>Sprawdź swoje zamówienia</h3>
        <form action="/search" method="GET">
            <input type="text" name="name" placeholder="Wpisz swoje imię i nazwisko z Facebooka" required>
            <button type="submit">Szukaj</button>
        </form>

        <hr>
        <h2>Ostatnie zamówienia</h2>
        <% if (orders.length === 0) { %>
            <p>Brak zamówień.</p>
        <% } else { %>
            <ul class="order-list">
                <% orders.forEach(order => { %>
                    <li>
                        <strong><%= order.userName %></strong> 
                        zamówił <%= order.quantity %>x <%= order.productKeyword %> 
                        <span class="status"><%= order.status %></span>
                        <small><%= new Date(order.timestamp).toLocaleString() %></small>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </div>
</body>
</html>