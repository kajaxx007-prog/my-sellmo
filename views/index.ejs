<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>🛒 <%= title %></h1>
        
        <!-- Nawigacja -->
        <div class="nav">
            <a href="/">Strona główna</a>
            <% if (user) { %>
                <a href="/admin">Panel Administratora</a>
                <span>Zalogowany jako: <%= user.username %> (<%= user.role %>)</span>
                <a href="/logout">Wyloguj się</a>
            <% } else { %>
                <a href="/login">Zaloguj się</a>
                <a href="/register">Zarejestruj się</a>
            <% } %>
        </div>
        
        <hr>
        
        <!-- Wyszukiwarka -->
        <div class="search-section">
            <h2>🔍 Znajdź swoje zamówienia</h2>
            <form action="/search" method="GET">
                <input type="text" name="name" placeholder="Wpisz swoje imię i nazwisko..." 
                       value="<%= searchedUser %>">
                <button type="submit" class="btn">Szukaj</button>
            </form>
        </div>
        
        <!-- Wyniki wyszukiwania -->
        <% if (searchedOrders.length > 0) { %>
        <div class="search-results">
            <h3>Wyniki dla: <%= searchedUser %></h3>
            <ul class="order-list">
                <% searchedOrders.forEach(order => { %>
                    <li>
                        <strong><%= order.userName %></strong> 
                        zamówił <%= order.quantity %>x <%= order.productKeyword %> 
                        <span class="status"><%= order.status %></span>
                        <small><%= new Date(order.timestamp).toLocaleString() %></small>
                    </li>
                <% }) %>
            </ul>
        </div>
        <hr>
        <% } %>
        
        <!-- Ostatnie zamówienia -->
        <h2>Ostatnie zamówienia</h2>
        <% if (orders.length === 0) { %>
            <p>Brak zamówień.</p>
        <% } else { %>
            <ul class="order-list">
                <% orders.forEach(order => { %>
                    <li>
                        <strong><%= order.userName %></strong> 
                        zamówił <%= order.quantity %>x <%= order.productKeyword %> 
                        <span class="status"><%= order.status %></span>
                        <small><%= new Date(order.timestamp).toLocaleString() %></small>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </div>
</body>
</html>