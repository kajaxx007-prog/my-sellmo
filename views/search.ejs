<!-- views/search.ejs -->
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Wyniki wyszukiwania</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h3>Wyniki dla "<%= query %>"</h3>
        <% if (groupedOrders.length === 0) { %>
            <p>Brak zamówień.</p>
        <% } else { %>
            <% groupedOrders.forEach(group => { %>
                <div style="border:1px solid #ccc; margin-bottom:15px; padding:10px; border-radius:8px;">
                    <h4 style="margin-top:0;">
                        <%= group.customerName %>
                        <% if (group.customerShortId) { %>
                            (ID: <%= group.customerShortId %>)
                        <% } %>
                        – <%= group.date %>
                    </h4>
                    <ul style="list-style-type: none; padding-left: 0;">
                        <% group.items.forEach(item => { %>
                            <li style="padding: 4px 0;">
                                <strong><%= item.productName %></strong> – 
                                <%= item.color %> / <%= item.size %>,
                                <%= item.quantity %> szt. × <%= item.price.toFixed(2) %> zł = 
                                <strong><%= (item.price * item.quantity).toFixed(2) %> zł</strong>
                            </li>
                        <% }) %>
                    </ul>
                    <p><strong>Łączna kwota: <%= group.totalAmount.toFixed(2) %> zł</strong></p>

                    <!-- Wyświetlanie statusów -->
                    <% if (group.orderIds.length === 1 || group.allSameStatus) { %>
                        <p><strong>Status zamówienia:</strong> <%= group.statuses[0] %></p>
                    <% } else { %>
                        <p><strong>Statusy pozycji:</strong></p>
                        <ul style="list-style-type: none; padding-left: 0;">
                            <% group.orderIds.forEach((orderId, index) => { %>
                                <li>Pozycja <%= index + 1 %> – <strong><%= group.statuses[index] %></strong></li>
                            <% }) %>
                        </ul>
                    <% } %>
                </div>
            <% }) %>
        <% } %>
        <p><a href="/">Powrót</a></p>
    </div>
</body>
</html>